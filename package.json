{
  "name": "packgod-browser",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.packgod.browser",
    "productName": "Packgod Browser",
    "files": [
      "**/*",
      "assets/**/*"
    ],
    "asar": true,

    "win": {
      "target": "nsis"
    },

    "linux": {
      "target": ["deb"]
    }
  }
}